{
  "name": "venture-os",
  "private": true,
  "version": "0.1.0",
  "description": "Venture OS — Africa-focused founder command center (docs + app).",
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "pnpm --dir app dev",
    "build": "pnpm --dir app build",
    "start": "pnpm --dir app start",
    "lint": "pnpm --dir app lint",
    "test": "pnpm --dir app test",
    "test:e2e": "pnpm --dir app test:e2e",
    "test:e2e:golden-path": "pnpm --dir app test:e2e:golden-path",
    "test:e2e:golden-path:witness": "GOLDEN_PATH_WRITE=1 pnpm test:e2e:golden-path",
    "ops:check": "node platform/scripts/ops-check.mjs",
    "workspace:check": "node platform/scripts/workspace/check.mjs",
    "agent:next-work": "node platform/scripts/agent/agent-next-work.mjs",
    "agent:work-selection:check": "node ../bridge-os/platform/scripts/checks/check-agent-work-selection.mjs",
    "mcp": "node ../baseline-os/platform/packages/baselineos/dist/cli/bin.js serve --mcp-only",
    "validate:rag-config": "node ../baseline-os/platform/scripts/validate-rag-config.mjs --root .",
    "validate:rag-config:write": "node platform/scripts/write-rag-config-evidence.mjs",
    "validate:mcp-config": "node platform/scripts/validate-split-ai-config.mjs --kind mcp",
    "validate:mcp-config:write": "node platform/scripts/validate-split-ai-config.mjs --kind mcp --write",
    "validate:graph-config": "node platform/scripts/validate-split-ai-config.mjs --kind graph",
    "validate:graph-config:write": "node platform/scripts/validate-split-ai-config.mjs --kind graph --write",
    "validate:eval-config": "node platform/scripts/validate-split-ai-config.mjs --kind eval",
    "validate:eval-config:write": "node platform/scripts/validate-split-ai-config.mjs --kind eval --write",
    "rag:eval": "node platform/scripts/run-rag-eval-smoke.mjs --golden config/baseline/rag-eval-golden.json --mock config/baseline/rag-eval-mock-corpus.json --out audit/evidence/rag-eval-latest.json",
    "pm:folder:check": "node ../bridge-os/platform/scripts/workspace/pm-folder-check.mjs",
    "agent:conduct:check": "node ../bridge-os/platform/scripts/checks/check-agent-conduct-local.mjs",
    "docs:foundation:check": "node platform/scripts/docs-foundation-check.mjs",
    "docs:foundation:check:write": "node platform/scripts/docs-foundation-check.mjs --write",
    "agent:exr-pack:validate": "node ../bridge-os/platform/scripts/evidence/validate-exr-pack.mjs",
    "ux:sor:check": "node ../bridge-os/platform/scripts/ecosystem/check-ux-sor.mjs --repo venture-os",
    "ux:sor:check:write": "node ../bridge-os/platform/scripts/ecosystem/check-ux-sor.mjs --repo venture-os --write",
    "agent:auto-dev:check": "node ../bridge-os/platform/scripts/checks/check-agent-auto-dev-local.mjs",
    "ops:consumption:check": "node ../bridge-os/platform/scripts/ecosystem/ops-consumption-check.mjs",
    "ops:consumption:check:write": "node ../bridge-os/platform/scripts/ecosystem/ops-consumption-check.mjs --write",
    "docs:architecture:check": "node platform/scripts/docs-architecture-check.mjs",
    "docs:architecture:check:write": "node platform/scripts/docs-architecture-check.mjs --write",
    "docs:product:check": "node platform/scripts/docs-product-check.mjs",
    "docs:product:check:write": "node platform/scripts/docs-product-check.mjs --write",
    "docs:product-charter:check": "node ../canon-os/platform/scripts/product-charter-forensic-check.mjs",
    "docs:product-charter:check:write": "node ../canon-os/platform/scripts/product-charter-forensic-check.mjs --write",
    "docs:roadmap:check": "node platform/scripts/docs-roadmap-check.mjs",
    "docs:ia:check": "node platform/scripts/docs-ia-check.mjs --write",
    "docs:tree:check": "node platform/scripts/docs-tree-check.mjs",
    "docs:tree:check:strict": "node platform/scripts/docs-tree-check.mjs --strict",
    "docs:check-links": "node platform/scripts/docs-link-check.mjs",
    "feature:production-package:check": "node platform/scripts/feature-production-package-check.mjs",
    "docs:operations:check": "node platform/scripts/docs-operations-check.mjs",
    "docs:operations:check:write": "node platform/scripts/docs-operations-check.mjs --write",
    "agile:check": "node platform/scripts/agile-check.mjs",
    "agile:check:write": "node platform/scripts/agile-check.mjs --write",
    "docs:agile:check": "node platform/scripts/agile-check.mjs",
    "docs:agile:check:write": "node platform/scripts/agile-check.mjs --write",
    "docs:fractal-mpr:check": "node platform/scripts/docs-fractal-mpr-check.mjs",
    "docs:pack:pillar-contract:check": "node platform/scripts/docs-pack-pillar-contract-check.mjs",
    "qasc:check": "pnpm --dir ../fabric-os qasc:repo -- --repo venture-os",
    "qasc:check:write": "pnpm --dir ../fabric-os qasc:repo:write -- --repo venture-os",
    "dslc:check": "pnpm --dir ../fabric-os dslc:release -- --manifest ../venture-os/pm/dslc/releases/REL-VENTURE-OS-001/manifest.json",
    "dslc:check:write": "pnpm --dir ../fabric-os dslc:release:write -- --manifest ../venture-os/pm/dslc/releases/REL-VENTURE-OS-001/manifest.json --output-root ../venture-os",
    "ship:check": "pnpm --dir ../fabric-os ship:release -- --manifest ../venture-os/pm/ship/releases/REL-VENTURE-OS-001/manifest.json",
    "ship:check:write": "pnpm --dir ../fabric-os ship:release:write -- --manifest ../venture-os/pm/ship/releases/REL-VENTURE-OS-001/manifest.json --output-root ../venture-os"
  }
}
