{
  "$schema": "gtcx://canon-os/docs-operations-pack/v1",
  "updated": "2026-06-16",
  "initiative": "INIT-DOCS-CORE-IA-V1",
  "title": "Docs operations pack — venture-os",
  "principle": "Human runbooks and agent ops narrative live under docs/operations/. P29 machine manifests stay under ops/ — link only, never duplicate domain state.",
  "requiredRootFiles": [
    {
      "path": "docs/operations/README.md",
      "role": "index + cross-ref (foundation ↔ operations ↔ ops/)"
    },
    {
      "path": "docs/operations/FOLDER-SPEC.md",
      "role": "repo-local mirror of this pack"
    }
  ],
  "requiredSubfolders": {
    "runbooks": {
      "purpose": "Operator runbooks — deployment, incident, recovery",
      "allowedDocTypes": [
        "runbook",
        "architecture"
      ],
      "required": [
        "README.md"
      ],
      "sourcePatterns": [
        "docs/_archive/guides/",
        "docs/reference/guides/"
      ]
    },
    "deployment": {
      "purpose": "Release and environment narratives — links ops/deploy bindings",
      "allowedDocTypes": [
        "runbook",
        "architecture"
      ],
      "required": [
        "README.md"
      ]
    },
    "agent-init": {
      "purpose": "Repo agent entry — session start, P22/P27 prose, git workflow. Fleet init → canon-os AGENT-INIT-CANON.",
      "allowedDocTypes": [
        "runbook",
        "overview"
      ],
      "required": [
        "README.md"
      ],
      "canonicalFiles": [
        "agent-universal-instructions.md"
      ],
      "sourcePatterns": [
        "agents/",
        "docs/operations/agent-universal-instructions.md"
      ]
    },
    "remediation": {
      "purpose": "Incident remediation playbooks — narrative only",
      "allowedDocTypes": [
        "runbook"
      ],
      "required": [
        "README.md"
      ],
      "optional": true
    },
    "coordination": {
      "purpose": "Cross-repo coordination narratives — bridge handoffs",
      "allowedDocTypes": [
        "runbook",
        "overview"
      ],
      "required": [
        "README.md"
      ],
      "optional": true,
      "hubNote": "canon-os + bridge-os host fleet coordination indexes"
    },
    "compliance": {
      "purpose": "Platform-runtime typed compliance instance artifacts — see docs-operations-compliance-nest.json",
      "allowedDocTypes": [
        "runbook",
        "overview",
        "assessment"
      ],
      "required": [
        "README.md"
      ],
      "optional": true,
      "platformRuntimeOnly": true,
      "nestSpec": "pm/spec/docs-operations-compliance-nest.json"
    }
  },
  "forbiddenAtOperationsRoot": [
    "Duplicate ops/ domain manifests (compliance, security, gtm JSON)",
    "Protocol bodies — belongs in docs/governance/protocols/",
    "Loose narrative *.md except README.md and FOLDER-SPEC.md when subfolders exist"
  ],
  "profiles": {
    "product": {
      "operationsRequired": true,
      "requiredSubfolders": [
        "runbooks",
        "deployment",
        "agent-init"
      ],
      "optionalSubfolders": [
        "remediation",
        "coordination"
      ]
    },
    "fleet-documentation": {
      "operationsRequired": true,
      "requiredSubfolders": [
        "runbooks",
        "agent-init",
        "coordination"
      ],
      "optionalSubfolders": [
        "deployment",
        "remediation"
      ]
    },
    "constitution-standards": {
      "operationsRequired": false,
      "allowed": "docs/operations/README.md pointer to ecosystem-os + canon-os ops narratives"
    },
    "platform": {
      "operationsRequired": true,
      "requiredSubfolders": [
        "runbooks",
        "deployment",
        "agent-init"
      ],
      "optionalSubfolders": [
        "remediation",
        "coordination"
      ]
    },
    "platform-runtime": {
      "operationsRequired": true,
      "extends": "platform",
      "requiredSubfolders": [
        "runbooks",
        "deployment",
        "agent-init",
        "compliance"
      ],
      "optionalSubfolders": [
        "remediation",
        "coordination"
      ],
      "complianceNestSpec": "pm/spec/docs-operations-compliance-nest.json",
      "complianceNestCheck": "pnpm docs:compliance-nest:check"
    }
  },
  "crossReference": {
    "opsMachineSoR": "ops/",
    "foundationLinks": [
      {
        "foundation": "goals.md",
        "operations": "runbooks/"
      }
    ],
    "referenceDecompose": {
      "docs/_archive/guides/": "relocate → docs/operations/runbooks/; pointer at _archive"
    }
  },
  "enforcement": {
    "check": "pnpm docs:operations:check",
    "fleetCheck": "pnpm ecosystem:docs:operations:fleet",
    "witness": "audit/evidence/docs-operations-latest.json",
    "fleetWitness": "audit/evidence/fleet-docs-operations-latest.json",
    "bootstrap": "node platform/scripts/fleet-docs-operations-bootstrap.mjs --write --all"
  },
  "repo": "venture-os",
  "upstreamSpec": "../canon-os/pm/spec/docs-operations-pack.json",
  "pillarContract": {
    "compliance": {
      "primary": true,
      "artifacts": [
        "docs/operations/FOLDER-SPEC.md"
      ],
      "gates": [
        "pnpm docs:operations:check"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "technicalExcellence": {
      "primary": true,
      "artifacts": [
        "docs/operations/runbooks/",
        "docs/operations/deployment/"
      ],
      "gates": [
        "commands + exit codes"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "craft": {
      "secondary": true,
      "artifacts": [
        "docs/operations/README.md"
      ],
      "gates": [
        "runbook index"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "worldClass": {
      "primary": true,
      "artifacts": [
        "docs/operations/runbooks/"
      ],
      "gates": [
        "global ops bars"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "trustAndSafety": {
      "primary": true,
      "artifacts": [
        "docs/operations/agent-init/"
      ],
      "gates": [
        "P27 execution obligation"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "creativityInnovation": {
      "notApplicable": true,
      "reason": "Innovation narratives live in docs/product/ and docs/architecture/; this layer routes only",
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "commercialValue": {
      "secondary": true,
      "artifacts": [
        "docs/operations/README.md"
      ],
      "gates": [
        "pilot unblock path"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "defensiveMoat": {
      "secondary": true,
      "artifacts": [
        "docs/operations/deployment/"
      ],
      "gates": [
        "proprietary deploy choreography"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "agenticEmpowerment": {
      "primary": true,
      "artifacts": [
        "docs/operations/agent-init/"
      ],
      "gates": [
        "agent ops narrative"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "ecosystemIntegration": {
      "secondary": true,
      "artifacts": [
        "docs/operations/integrations/"
      ],
      "gates": [
        "cross-repo runbooks"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    },
    "ipMagic": {
      "notApplicable": true,
      "reason": "IP magic scored in docs/product/acceptance and reference implementations",
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-operations-layer-latest.json"
    }
  },
  "fractalMpr": {
    "policy": "pm/spec/docs-fractal-mpr-policy.json",
    "layerWitness": "audit/evidence/mpr-operations-layer-latest.json",
    "scorecard": "docs/operations/scorecard.md",
    "rollupFrom": [
      "file",
      "folder"
    ],
    "scorecardIsReadOnlyRollup": true
  }
}
