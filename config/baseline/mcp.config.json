{
  "$schema": "gtcx://ecosystem-os/mcp-config/v1",
  "repo": "venture-os",
  "mode": "consumer",
  "server": "venture-os",
  "tools": [
    {
      "id": "venture.founder.context.read",
      "permissionClass": "read",
      "description": "Read founder command center, capital filter, workflow, and readiness context."
    },
    {
      "id": "venture.investment.context.read",
      "permissionClass": "read",
      "description": "Read investment memorandum, approvals, publishing, and market readiness context."
    },
    {
      "id": "venture.evidence.write",
      "permissionClass": "write",
      "description": "Write local Venture evidence and graph/RAG/MCP witnesses under audit/evidence."
    }
  ],
  "permissions": [
    "read:repo-files",
    "read:founder-context",
    "read:investment-context",
    "write:audit-evidence"
  ],
  "humanApprovalRequired": [
    "write:sibling-repos",
    "external-network",
    "deploy",
    "send-email",
    "change-git-history"
  ]
}
