{
  "version": "1.0.0",
  "description": "Venture OS Phase 2 — n8n workflow stubs for inbound capture and rolling brief digest",
  "workflows": [
    {
      "id": "venture-inbound-capture",
      "name": "Venture Inbound Capture",
      "trigger": {
        "type": "webhook",
        "path": "venture/inbound",
        "method": "POST"
      },
      "steps": [
        {
          "id": "normalize",
          "type": "function",
          "description": "Map payload to VentureOpportunity schema (source, title, clientId, urgency)"
        },
        {
          "id": "clickup-create",
          "type": "clickup",
          "description": "Create task in Venture Opportunities list with custom fields"
        },
        {
          "id": "receipt",
          "type": "http",
          "description": "POST selection receipt to fabric-os ledger (future — fabric-os#106)"
        }
      ],
      "env": ["CLICKUP_API_TOKEN", "CLICKUP_LIST_ID", "FABRIC_RECEIPT_URL"]
    },
    {
      "id": "venture-rolling-digest",
      "name": "Venture Rolling Brief Digest",
      "trigger": {
        "type": "cron",
        "expression": "0 7 * * 1-5",
        "timezone": "America/New_York"
      },
      "steps": [
        {
          "id": "fetch-pipeline",
          "type": "clickup",
          "description": "Pull open opportunities + approvals due in 72h"
        },
        {
          "id": "compose-brief",
          "type": "function",
          "description": "Render markdown brief (matches app/lib/brief.ts format)"
        },
        {
          "id": "gmail-send",
          "type": "gmail",
          "description": "Send digest to founder with label venture/brief"
        }
      ],
      "env": ["CLICKUP_API_TOKEN", "GMAIL_OAUTH_CREDENTIALS", "FOUNDER_EMAIL"]
    }
  ]
}
