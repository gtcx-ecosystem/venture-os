{
  "$schema": "gtcx://agentic/bridge/v1",
  "schema": "gtcx.agentic.bridge.v1",
  "repo": "venture-os",
  "role": "thin-bridge",
  "updated": "2026-06-08",
  "baseline": {
    "provider": "baseline-os",
    "resolvedAt": "../baseline-os",
    "cliEntry": "../baseline-os/platform/packages/baselineos/dist/cli/bin.js",
    "verbs": {
      "session": "pnpm session",
      "next": "pnpm next",
      "gates": "pnpm gates",
      "hub": "pnpm hub"
    },
    "mnemonic": "session → next → gates → hub"
  },
  "bridge-os": {
    "provider": "bridge-os",
    "resolvedAt": "../bridge-os",
    "role": "ecosystem-program-office",
    "verbs": {
      "zenhub:status": "pnpm --dir ../bridge-os ecosystem:zenhub:status",
      "zenhub:plan": "pnpm --dir ../bridge-os ecosystem:zenhub:plan",
      "zenhub:apply": "pnpm --dir ../bridge-os ecosystem:zenhub:apply",
      "ecosystem:p35:check": "pnpm --dir ../bridge-os ecosystem:p35:check -- --repo venture-os",
      "fleet:readiness": "pnpm --dir ../bridge-os ecosystem:fleet:readiness -- --repo venture-os",
      "deploy:readiness": "pnpm --dir ../bridge-os ecosystem:deploy:readiness -- --repo venture-os",
      "skills:rollout": "pnpm --dir ../bridge-os ecosystem:skills:rollout -- --repo venture-os",
      "cursor:rollout": "pnpm --dir ../bridge-os ecosystem:cursor:rollout -- --repo venture-os"
    }
  },
  "skills": {
    "provider": "bridge-os",
    "resolvedAt": "../bridge-os",
    "source": "../bridge-os/docs/reference/skills",
    "overlaySoR": "../bridge-os/pm/spec/skills-ecosystem-map.json",
    "cursorRules": ".cursor/rules/skill-*.mdc",
    "claudeCode": ".claude/skills/",
    "verbs": {
      "build": "pnpm --dir ../bridge-os skills:build",
      "build:check": "pnpm --dir ../bridge-os skills:build:check",
      "create": "pnpm --dir ../bridge-os skill:create"
    },
    "precedence": "GTCX P22/P26/P27/P28 win over skill HARD-GATEs — see ../bridge-os/docs/reference/skills/README.md#precedence-vs-gtcx-protocols"
  },
  "directiveSources": {
    "primary": "pm/",
    "ecosystemPlan": "../bridge-os/pm/",
    "rejected": ["fat-hub-in-product-repo"]
  },
  "integrationCatalogs": {
    "bridge-os": "../bridge-os",
    "gtcx-os": "../gtcx-os",
    "scope": "bridge-os = coordination + ZenHub SoR; gtcx-os = monorepo shell (read-only)"
  },
  "protocols": {
    "P22": "work selection from local pm/backlog.json",
    "P24": "cross-repo handoffs via bridge-os + 01-docs/06-coordination/",
    "P27": "agents run commands; report exit codes",
    "P35": "pm/ is local SoR (v5 layout)",
    "P36": "engine outputs are not hand-edited; agileHub null on product repos"
  },
  "completionLoop": {
    "modelPath": "pm/completion-model.json",
    "activeWorkKey": "definitionOfDone.activeWork",
    "currentlyActive": false,
    "rule": "backlogClear must be false while activeWork DoD is unmet; T0-gate-feed audit sources are not closure evidence"
  }
}
