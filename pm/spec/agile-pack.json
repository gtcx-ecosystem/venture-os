{
  "$schema": "gtcx://canon-os/agile-pack/v1",
  "updated": "2026-06-16",
  "initiative": "INIT-DOCS-CORE-IA-V1",
  "wave": "W11b",
  "title": "Docs agile pack — venture-os",
  "principle": "agile-os is the tactical Chief Product Officer (CPO) of the GTCX ecosystem. Each repo owns repo-root agile/ (P35 hub — not under docs/) — local ceremony workspace plugging into the CPO loop. Fleet backlog and ceremony law stay in agile-os.",
  "cpoRole": {
    "fleetCpoRepo": "agile-os",
    "charter": "../agile-os/docs/strategy/fleet-agile-hub.md",
    "productGoals": "../agile-os/pm/spec/product-goals.json",
    "prd": "../agile-os/pm/product/fleet-agile-hub-prd.md",
    "loop": "OBSERVE → ANTICIPATE → DECIDE → EXECUTE → VERIFY → LEARN",
    "northStar": "Fleet work flows through agile-os before it flows anywhere else",
    "compositeTarget": {
      "productRepo": "≥85/100 per pillar at repo audit order",
      "fleetAgileHub": "100/100 on all eleven pillars — tactical CPO reference implementation"
    }
  },
  "canonicalPath": "agile",
  "referenceImplementation": {
    "repo": "agile-os",
    "path": "../agile-os/agile",
    "templateSlices": [
      "sprints/slice-01",
      "sprints/slice-02"
    ],
    "fleetBacklog": "../agile-os/pm/ecosystem-sprint-backlog.json",
    "zenhubPlan": "../agile-os/pm/zenhub-plan.json",
    "zenhubRegistry": "../bridge-os/config/zenhub-ecosystem-registry.json",
    "strategy": "../agile-os/docs/strategy/fleet-agile-hub.md"
  },
  "pillarContract": {
    "compliance": {
      "primary": true,
      "artifacts": [
        "agile/intake.md",
        "agile/zenhub.md",
        "agile/scorecard.md"
      ],
      "gates": [
        "pnpm agile:check",
        "P22 trace documented in intake.md",
        "zenhub label contract in zenhub.md"
      ],
      "minBar": "≥85 repo order; agile-os hub ≥100",
      "witness": "audit/evidence/agile-latest.json"
    },
    "technicalExcellence": {
      "primary": false,
      "secondary": true,
      "artifacts": [
        "agile/qa-uat.md",
        "agile/planning.md"
      ],
      "gates": [
        "qa-uat lists CI gates with commands",
        "planning.md DoR references test/validate"
      ],
      "minBar": "qa-uat.md names repo verify commands with exit-code expectation"
    },
    "craft": {
      "secondary": true,
      "artifacts": [
        "agile/README.md",
        "agile/FOLDER-SPEC.md"
      ],
      "gates": [
        "ceremony surface table in README",
        "no loose md at agile root"
      ],
      "minBar": "flat ceremony files ≤500 lines unless reference/strategy exempt"
    },
    "worldClass": {
      "secondary": true,
      "artifacts": [
        "agile/planning.md",
        "agile/scorecard.md"
      ],
      "gates": [
        "prioritization rubric present",
        "time-to-first-sprint path in README"
      ],
      "minBar": "new repo onboard ≤1 day per GOAL-ADOPTION"
    },
    "trustAndSafety": {
      "secondary": true,
      "artifacts": [
        "agile/intake.md",
        "agile/cpo.md"
      ],
      "gates": [
        "Class A/S escalation path in intake",
        "authority boundary vs agile-os CPO"
      ],
      "minBar": "no fleet backlog fork in product repos"
    },
    "creativityInnovation": {
      "notApplicable": true,
      "reason": "Innovation narratives live in docs/product/ux/ and docs/architecture/; agile layer routes intake only"
    },
    "commercialValue": {
      "primary": true,
      "artifacts": [
        "agile/planning.md",
        "agile/intake.md"
      ],
      "gates": [
        "prioritization rubric links pm/ and business value",
        "milestone trace in planning"
      ],
      "minBar": "every committed story traces to prdRef or capabilityId",
      "witness": "ops/pm/backlog.json"
    },
    "defensiveMoat": {
      "secondary": true,
      "artifacts": [
        "agile/zenhub.md",
        "agile/cpo.md"
      ],
      "gates": [
        "zenhub dependsOn hygiene",
        "fleet-only decision trace via agile-os"
      ],
      "minBar": "product repo links moat SoR — does not duplicate agile-os velocity corpus"
    },
    "agenticEmpowerment": {
      "primary": true,
      "artifacts": [
        "agile/intake.md",
        "agile/planning.md"
      ],
      "gates": [
        "pnpm agent:next-work trace documented",
        "P22 delegation rules in intake"
      ],
      "minBar": "≥95% P22 trace coverage fleet-wide per GOAL-AUTHORITY",
      "witness": "pm/ci/sprint-authority-check-latest.json"
    },
    "ecosystemIntegration": {
      "primary": true,
      "artifacts": [
        "agile/intake.md",
        "agile/zenhub.md",
        "agile/cpo.md"
      ],
      "gates": [
        "ops/pm/manifest.json agileDocs binding",
        "fleet backlog intake link"
      ],
      "minBar": "cross-repo items reference ownerRepo + XR id",
      "witness": "audit/evidence/fleet-agile-latest.json"
    },
    "ipMagic": {
      "notApplicable": true,
      "reason": "Signature operator moments live in docs/product/ux/ and agile/qa-uat.md"
    }
  },
  "requiredRootFiles": [
    {
      "path": "agile/README.md",
      "role": "index — CPO loop, ceremony map, pillar scorecard link"
    },
    {
      "path": "agile/FOLDER-SPEC.md",
      "role": "repo-local mirror of this pack"
    },
    {
      "path": "agile/cpo.md",
      "role": "CPO connection — agile-os charter link + repo sprint authority boundary"
    },
    {
      "path": "agile/scorecard.md",
      "role": "11-pillar self-assessment for this agile layer"
    },
    {
      "path": "agile/intake.md",
      "role": "inbound work, handoffs, repo backlog intake"
    },
    {
      "path": "agile/planning.md",
      "role": "sprint planning, prioritization rubric, DoR"
    },
    {
      "path": "agile/qa-uat.md",
      "role": "QA gates + UAT plan and evidence"
    },
    {
      "path": "agile/zenhub.md",
      "role": "board hygiene, label contract, workspace bindings"
    }
  ],
  "optionalRootFiles": [
    {
      "path": "agile/roadmap.md",
      "role": "repo-local execution lens (optional when planning.md covers it)"
    },
    {
      "path": "agile/team.md",
      "role": "ceremony roster (optional when planning.md covers it)"
    }
  ],
  "requiredSubfolders": {
    "roadmaps": {
      "purpose": "Roadmap lane narratives — technical, gtm, legal, partnerships, ux-design",
      "allowedDocTypes": [
        "overview",
        "roadmap"
      ],
      "required": [
        "README.md",
        "technical.md",
        "gtm.md"
      ],
      "optionalFiles": [
        "legal.md",
        "partnerships.md",
        "ux-design.md",
        "compliance.md"
      ],
      "forbiddenIn": [
        "docs/roadmap/",
        "pm/roadmap/",
        "docs/product/roadmaps/"
      ]
    },
    "scrum": {
      "purpose": "Scrum ceremony — DoD, DoR, standup, story template, epic template",
      "allowedDocTypes": [
        "protocol",
        "runbook",
        "overview"
      ],
      "required": [
        "README.md",
        "definition-of-done.md",
        "definition-of-ready.md"
      ],
      "optionalFiles": [
        "backlog.md",
        "sprint-planning.md",
        "retrospective.md",
        "standup.md",
        "story-template.md",
        "epic.md"
      ],
      "templateSource": "agile-os/agile/sprints/slice-01"
    },
    "requirements": {
      "purpose": "Delivery requirements trace — story/epic ↔ FR ID links; FR prose in docs/architecture/requirements/",
      "allowedDocTypes": [
        "overview",
        "protocol"
      ],
      "required": [
        "README.md",
        "trace.md"
      ],
      "forbidden": [
        "Duplicate functional-requirements catalog — docs/architecture/requirements/ only"
      ]
    },
    "sprints": {
      "purpose": "Active sprint slice — current.md + sealed history",
      "allowedDocTypes": [
        "overview",
        "runbook"
      ],
      "required": [
        "README.md",
        "current.md"
      ],
      "templateSource": "agile-os/agile/sprints",
      "optional": true
    },
    "archive": {
      "purpose": "Sealed sprint snapshots",
      "required": [
        "README.md"
      ],
      "optional": true
    }
  },
  "forbiddenAtAgileRoot": [
    "Duplicate pm/ecosystem-sprint-backlog.json bodies in product repos",
    "Fleet-wide ceremony law — belongs in agile-os",
    "Loose narrative *.md except pack requiredRootFiles + optionalRootFiles"
  ],
  "forbiddenUnderDocsAbsent": [
    {
      "path": "docs/agile",
      "canonical": "agile/",
      "rule": "repo-root only — delete docs/agile/ entirely"
    }
  ],
  "forbiddenShadowPaths": [
    {
      "path": "docs/roadmap/agile",
      "rule": "pointer-only to agile/"
    },
    {
      "path": "docs/operations/agile",
      "rule": "pointer-only to agile/"
    },
    {
      "path": "docs/reference/agile",
      "rule": "pointer-only to agile/"
    }
  ],
  "profiles": {
    "product": {
      "agileRequired": true,
      "pillarTarget": 85,
      "requiredSubfolders": [
        "scrum",
        "roadmaps",
        "requirements"
      ],
      "optionalSubfolders": [
        "sprints",
        "archive"
      ]
    },
    "platform": {
      "agileRequired": true,
      "pillarTarget": 85,
      "requiredSubfolders": [
        "scrum",
        "roadmaps",
        "requirements",
        "sprints"
      ],
      "optionalSubfolders": [
        "archive"
      ]
    },
    "fleet-agile": {
      "agileRequired": true,
      "isReferenceImpl": true,
      "isFleetCpo": true,
      "pillarTarget": 100,
      "requiredSubfolders": [
        "scrum",
        "sprints",
        "archive"
      ],
      "hubLinks": [
        "pm/ecosystem-sprint-backlog.json",
        "pm/execution-roadmap.md",
        "pm/zenhub-plan.json",
        "pm/spec/product-goals.json",
        "pm/product/fleet-agile-hub-prd.md",
        "docs/strategy/fleet-agile-hub.md"
      ],
      "hubGates": [
        "pnpm ops:check",
        "pnpm ecosystem:ceremony:check",
        "pnpm ecosystem:zenhub:deps:check",
        "pnpm ecosystem:sprint-authority:check"
      ]
    },
    "fleet-documentation": {
      "agileRequired": true,
      "pillarTarget": 85,
      "requiredSubfolders": [],
      "optionalSubfolders": [
        "scrum",
        "sprints",
        "archive"
      ]
    },
    "constitution-standards": {
      "agileRequired": false,
      "allowed": "agile/README.md pointer to agile-os CPO reference"
    }
  },
  "crossReference": {
    "roadmapParent": "docs/roadmap/",
    "machinePmSoR": "pm/",
    "pillarMetaSpec": "pm/spec/docs-folder-pillar-contract.json",
    "opsBinding": {
      "manifest": "ops/pm/manifest.json",
      "localAgileDocsKey": "local.agileDocs",
      "expectedValue": "agile"
    },
    "fleetBacklogIntake": {
      "source": "../agile-os/pm/ecosystem-sprint-backlog.json",
      "localSlice": "ops/pm/backlog.json",
      "syncCommand": "pnpm pm:sync"
    }
  },
  "enforcement": {
    "check": "pnpm agile:check",
    "witness": "audit/evidence/agile-latest.json",
    "gateSchema": "v1",
    "fleetCheck": "pnpm ecosystem:docs:agile:fleet",
    "fleetWitness": "audit/evidence/fleet-agile-latest.json",
    "bootstrap": "node platform/scripts/fleet-agile-bootstrap.mjs --write --all",
    "requiredGates": [
      "pillarContract:complete",
      "scorecard:eleven-pillars",
      "cpo:charter-link",
      "ceremony-surface:complete"
    ],
    "rehome": "node platform/scripts/fleet-agile-root-rehome.mjs --write --all"
  },
  "repo": "venture-os",
  "upstreamSpec": "../canon-os/pm/spec/agile-pack.json",
  "fractalMpr": {
    "policy": "pm/spec/docs-fractal-mpr-policy.json",
    "layerWitness": "audit/evidence/mpr-agile-layer-latest.json",
    "scorecard": "agile/scorecard.md",
    "rollupFrom": [
      "file",
      "folder"
    ],
    "scorecardIsReadOnlyRollup": true
  }
}
