    "pm/spec/docs-foundation-pack.json",
    "pm/spec/docs-business-pack.json",
    "pm/spec/docs-architecture-pack.json",
    "pm/spec/docs-product-pack.json",
    "pm/spec/docs-roadmap-pack.json",
    "pm/spec/docs-operations-pack.json"
  ],
  "repoRootHubs": {
    "outsideDocs": [
      { "id": "agile", "path": "agile/", "pack": "pm/spec/agile-pack.json" },
      { "id": "agents", "path": "agents/", "pack": "pm/spec/agents-pack.json" }
    ],
    "forbiddenUnderDocs": ["docs/agile", "docs/agents"]
  },
  "universal": {
    "rootContract": {
      "spec": "pm/spec/docs-root-contract.json",
      "principle": "thin instances â€” link fleet SoR; repo-specific substance only",
      "templates": "docs/reference/templates/docs/types/"
    },
    "docsRootRequired": [
      { "path": "docs/README.md", "role": "human map â€” profile, layer table, central IA links" },
      { "path": "docs/INDEX.md", "role": "agent manifest â€” forbidden paths, sor note, fleet read-order link" },
      { "path": "docs/sor.json", "role": "machine SoR â€” repoKind, path variants" },
      { "path": "docs/conventions.md", "role": "repo deltas + link to hub naming law" },
      { "path": "docs/CHANGELOG.md", "role": "structural changelog only" }
    ],
    "docsRootRequiredHubOnly": [
      { "path": "docs/FOLDER-SPEC.md", "role": "root provisioning mirror â€” canon-os only" }
    ],
    "layerRootAllowlist": [
      "README.md",
      "FOLDER-SPEC.md",
      "scorecard.md",
      "index.md",
      "INDEX.md"
    ],
    "foundationRootExtra": [
