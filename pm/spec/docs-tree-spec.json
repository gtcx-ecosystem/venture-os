  "protocol": "docs/governance/protocols/48-docs-provisioning-standard/protocol.md",
  "rootContractSpec": "pm/spec/docs-root-contract.json",
  "title": "Docs tree spec â€” composed from per-folder specs (when approved)",
  "principle": "Composed from pm/spec/docs-folders/ one folder at a time. Do not enforce until INDEX queue entries are approved. Specs use updated date only â€” no semver version fields.",
  "incrementalProgram": {
    "index": "pm/spec/docs-folders/INDEX.json",
    "next": "01-foundation",
    "composeWhen": "all required folder specs status approved"
  },
  "masterOf": [
    "docs/ top-level taxonomy",
    "docs/ root contract",
    "universal folder + file invariants",
    "forbidden and deprecated paths",
    "profile â†’ required layers"
  ],
