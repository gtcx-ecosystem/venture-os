      "folderSpecWhen": { "mdCountGte": 3, "orSubfolderCountGte": 1 },
      "topLevelLayerRequiresFolderSpec": true
    },
    "everyMarkdown": {
      "requiresFrontmatter": true,
      "requiresDocumentType": true,
      "exemptBasenames": ["CHANGELOG.md"],
      "exemptRoles": ["README.md", "FOLDER-SPEC.md", "INDEX.md", "index.md"],
      "pointerStatusExempt": true,
      "registry": "pm/spec/docs-document-types.json"
    },
