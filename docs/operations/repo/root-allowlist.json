    "audits": "Use audit/ and archive legacy audit reports.",
    "reports": "Use audit/reports/ or archive legacy reports.",
    "ops": "Use operations/ for operational records.",
    "pm": "Use machine/ for machine-readable product management records."
  },
  "relocate_hints": {
    "agentic": "archive/legacy-agentic-2026-07-01/",
    "audits": "archive/legacy-audits-2026-07-01/",
    "reports": "archive/legacy-reports-2026-07-01/",
    "ops": "archive/_delete/ops/",
    "pm": "archive/_delete/pm/"
