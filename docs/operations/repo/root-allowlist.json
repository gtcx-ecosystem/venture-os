  "migration_tier": "stable",
  "required_files": [
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md"
  ],
  "required_directories": [
    "archive",
    "docs",
    "operations",
    "platform",
    "deploy",
    "audit",
    "workstream",
    "config",
    "agents",
    "machine",
    "app",
    "clients",
    "prototype",
    "schema",
    "agile"
  ],
  "allowed_files": [
    "LICENSE",
    "NOTICE",
    "package.json",
    "pnpm-workspace.yaml",
    "pnpm-lock.yaml",
    "baseline.config.json",
    ".dockerignore",
    ".gitignore"
  ],
  "allowed_directories": [
    "archive",
    "docs",
    "operations",
    "platform",
    "deploy",
    "audit",
    "workstream",
    "config",
    "agents",
    "machine",
    "app",
    "clients",
    "prototype",
    "schema",
    "agile"
  ],
