{
  "$schema": "./root-allowlist.schema.json",
  "version": "5.0.0",
  "schema_version": "5.0.0",
  "updated": "2026-07-01",
  "description": "P35 v5 closed-world repo root for venture-os.",
  "migration_tier": "stable",
  "required_files": [
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md"
  ],
  "required_directories": [
    "archive",
    "docs",
    "ops",
    "platform",
    "deploy",
    "audit",
    "workstream",
    "config",
    "agents",
    "pm",
    "agile",
    "app",
    "clients",
    "prototype",
    "schema"
  ],
  "allowed_files": [
    "LICENSE",
    "NOTICE",
    "package.json",
    "pnpm-workspace.yaml",
    "pnpm-lock.yaml",
    "baseline.config.json",
    ".dockerignore",
    ".gitignore"
  ],
  "allowed_directories": [
    "archive",
    "docs",
    "ops",
    "platform",
    "deploy",
    "audit",
    "workstream",
    "config",
    "agents",
    "pm",
    "agile",
    "app",
    "clients",
    "prototype",
    "schema"
  ],
  "allowed_dot_directories": [
    ".github",
    ".husky",
    ".agent",
    ".baseline",
    ".cursor",
    ".claude",
    ".superpowers"
  ],
  "ignored_prefixes": [
    ".",
    "node_modules"
  ],
  "ignored_exact": [
    "node_modules",
    "tsconfig.tsbuildinfo"
  ],
  "forbidden_root_names": {
    "01-docs": "Use docs/ + pm/ (P35 v5).",
    "03-platform": "Use platform/ (P35 v5).",
    "agentic": "Use agents/ and archive legacy agentic records.",
    "audits": "Use audit/ and archive legacy audit reports.",
    "machine": "Use pm/ for machine-readable product management records.",
    "reports": "Use audit/reports/ or archive legacy reports."
  },
  "relocate_hints": {
    "agentic": "archive/legacy-agentic-2026-07-01/",
    "audits": "archive/legacy-audits-2026-07-01/",
    "machine": "archive/legacy-machine-2026-07-01/",
    "reports": "archive/legacy-reports-2026-07-01/"
  }
