{
  "version": "1.0.0",
  "description": "Venture OS Phase 3 — n8n workflow stubs for inbound capture and rolling brief digest",
  "workflows": [
    {
      "id": "venture-inbound-capture",
      "name": "Venture Inbound Capture",
      "trigger": {
        "type": "webhook",
        "path": "/api/venture/inbound",
        "method": "POST"
      },
      "steps": [
        {
          "id": "normalize",
          "type": "function",
          "description": "Map payload to VentureOpportunity schema (source, title, clientId, urgency)"
        },
        {
          "id": "clickup-create",
          "type": "clickup",
          "description": "Create task in Venture Opportunities list with custom fields"
        },
        {
          "id": "receipt",
          "type": "http",
          "description": "POST automation receipt to Venture OS store; fabric-os ledger when FABRIC_RECEIPT_URL set (fabric-os#106)"
        }
      ],
      "env": ["CLICKUP_API_TOKEN", "CLICKUP_LIST_ID", "FABRIC_RECEIPT_URL"]
    },
    {
      "id": "venture-rolling-digest",
      "name": "Venture Rolling Brief Digest",
      "trigger": {
        "type": "cron",
        "expression": "0 7 * * 1-5",
        "timezone": "America/New_York"
      },
      "steps": [
        {
          "id": "fetch-pipeline",
          "type": "clickup",
          "description": "Pull open opportunities + approvals due in 72h"
        },
        {
          "id": "compose-brief",
          "type": "function",
          "description": "Render markdown brief (matches app/lib/brief.ts format)"
        },
        {
          "id": "gmail-send",
          "type": "gmail",
          "description": "Send digest to founder with label venture/brief"
        }
      ],
      "env": ["CLICKUP_API_TOKEN", "GMAIL_OAUTH_CREDENTIALS", "FOUNDER_EMAIL"]
    },
    {
      "id": "venture-newsletter-send",
      "name": "Venture Newsletter Send (Listmonk)",
      "trigger": {
        "type": "webhook",
        "path": "/api/venture/newsletter",
        "method": "POST"
      },
      "steps": [
        {
          "id": "validate-approval",
          "type": "function",
          "description": "Require approvalStatus approved + briefId when present"
        },
        {
          "id": "compose-campaign",
          "type": "http",
          "description": "POST Venture OS newsletter rail (dryRun true by default)"
        },
        {
          "id": "listmonk-dispatch",
          "type": "http",
          "description": "Optional: POST /api/campaigns when dryRun false and LISTMONK_* configured"
        }
      ],
      "env": ["LISTMONK_URL", "LISTMONK_API_USER", "LISTMONK_API_TOKEN", "VENTURE_WEBHOOK_SECRET"]
    },
    {
      "id": "venture-miniflux-ingest",
      "name": "Venture Miniflux RSS Ingest",
      "trigger": {
        "type": "webhook",
        "path": "/api/venture/sources/miniflux",
        "method": "POST"
      },
      "steps": [
        {
          "id": "forward-entry",
          "type": "http",
          "description": "Forward Miniflux entry payload; resolve client via feed id in newsletter-source-registry.json"
        }
      ],
      "env": ["VENTURE_WEBHOOK_SECRET", "MINIFLUX_WEBHOOK_SECRET"]
    },
    {
      "id": "venture-gmail-source-ingest",
      "name": "Venture Gmail Label Ingest",
      "trigger": {
        "type": "gmail",
        "description": "New message on VO/{client}/inbox-opportunities or visibility labels"
      },
      "steps": [
        {
          "id": "normalize-label",
          "type": "function",
          "description": "Map Gmail message to label, messageId, subject, snippet"
        },
        {
          "id": "post-venture",
          "type": "http",
          "description": "POST /api/venture/sources/gmail"
        }
      ],
      "env": ["GMAIL_OAUTH_CREDENTIALS", "VENTURE_WEBHOOK_SECRET", "GMAIL_WEBHOOK_SECRET"]
    }
  ]
}
