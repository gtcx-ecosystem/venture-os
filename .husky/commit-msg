#!/bin/sh
msg=$(cat "$1")
echo "$msg" | head -1 | grep -qE '^(feat|fix|docs|chore|refactor|test|style|perf|ci|build)(\([a-z0-9-]+\))?: .+' || {
  echo "GATE-COMMIT BLOCK: conventional commit required"
  exit 1
}
node "../bridge-os/platform/scripts/ecosystem/check-hard-lane-commit-msg.mjs" "$1" || exit 1
