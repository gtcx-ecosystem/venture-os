{
  "$schema": "gtcx://canon-os/docs-roadmap-pack/v1",
  "updated": "2026-06-16",
  "initiative": "INIT-DOCS-CORE-IA-V1",
  "title": "Docs roadmap pack — venture-os",
  "canonicalPath": "machine/roadmap/lanes",
  "principle": "Lane narratives → agile/roadmaps/. Executable plan SoR → docs/product/roadmap/ (P57). Legacy docs/roadmap/ → pointer-only.",
  "requiredRootFiles": [
    {
      "path": "agile/roadmaps/README.md",
      "role": "index + lane definitions + pointer rules"
    }
  ],
  "canonicalLaneFiles": [
    "technical.md",
    "gtm.md",
    "legal.md",
    "partnerships.md",
    "ux-design.md",
    "compliance.md"
  ],
  "legacyPointer": {
    "path": "docs/roadmap/",
    "canonical": "agile/roadmaps/",
    "rule": "pointer-only README if folder exists"
  },
  "_deprecatedRequiredRootFiles": [
    "docs/roadmap/README.md",
    "docs/roadmap/FOLDER-SPEC.md",
    "docs/roadmap/roadmap-current.md"
  ],
  "requiredSubfolders": {
    "technical": {
      "purpose": "Technical roadmap lane — links to docs/architecture/specs/* + pm/* execution truth",
      "required": [
        "README.md",
        "roadmap.md"
      ]
    },
    "ux-design": {
      "purpose": "UX/design roadmap lane — links to docs/product/*",
      "required": [
        "README.md",
        "roadmap.md"
      ]
    },
    "gtm": {
      "purpose": "GTM roadmap lane — links to ops/gtm/* + docs/business/* (no duplication of ops manifests)",
      "required": [
        "README.md",
        "roadmap.md"
      ]
    },
    "legal": {
      "purpose": "Legal lane — links to ops/legal/* and/or docs/operations/legalops-* (narrative only)",
      "required": [
        "README.md",
        "roadmap.md"
      ]
    },
    "compliance": {
      "purpose": "Compliance lane — links to ops/compliance/* + docs/operations/compliance/* (narrative only)",
      "required": [
        "README.md",
        "roadmap.md"
      ]
    },
    "agile": {
      "purpose": "Pointer stub only — canonical agile hub is repo-root agile/; pack: agile-pack.json; reference: agile-os",
      "required": [
        "README.md"
      ],
      "packRef": "pm/spec/agile-pack.json"
    },
    "partnerships": {
      "purpose": "Partnerships lane — links to docs/business/partnerships/* (+ ops bindings if any)",
      "required": [
        "README.md",
        "roadmap.md"
      ]
    },
    "archive": {
      "purpose": "Immutable dated snapshots (roadmap-YYYY-MM-DD.md)",
      "required": [
        "README.md"
      ],
      "optional": true
    }
  },
  "forbiddenDuplicates": [
    "docs/foundation/roadmap.md must be pointer-only to docs/roadmap/roadmap-current.md",
    "No roadmaps under docs/strategy/**",
    "No roadmaps under docs/overview/**",
    "No roadmaps under docs/product/roadmap/**",
    "No roadmaps under docs/architecture/roadmap/**"
  ],
  "profiles": {
    "product": {
      "roadmapRequired": true
    },
    "fleet-documentation": {
      "roadmapRequired": true
    },
    "constitution-standards": {
      "roadmapRequired": false,
      "allowed": "pointer-only README.md is allowed"
    },
    "platform": {
      "roadmapRequired": true
    }
  },
  "enforcement": {
    "check": "pnpm docs:roadmap:check",
    "witness": "audit/evidence/docs-roadmap-latest.json",
    "gateSchema": "v1",
    "fleetCheck": "pnpm ecosystem:docs:roadmap:fleet",
    "fleetWitness": "audit/evidence/fleet-docs-roadmap-latest.json",
    "bootstrap": "node platform/scripts/fleet-docs-roadmap-bootstrap.mjs --write --all"
  },
  "repo": "venture-os",
  "upstreamSpec": "../canon-os/pm/spec/docs-roadmap-pack.json",
  "pillarContract": {
    "compliance": {
      "primary": true,
      "artifacts": [
        "docs/roadmap/README.md"
      ],
      "gates": [
        "pnpm docs:roadmap:check"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    },
    "technicalExcellence": {
      "secondary": true,
      "artifacts": [
        "docs/roadmap/technical/"
      ],
      "gates": [
        "lane READMEs"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    },
    "craft": {
      "secondary": true,
      "artifacts": [
        "docs/roadmap/README.md"
      ],
      "gates": [
        "single-home lanes"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    },
    "worldClass": {
      "secondary": true,
      "artifacts": [
        "docs/roadmap/README.md"
      ],
      "gates": [
        "prioritization rubric"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    },
    "trustAndSafety": {
      "secondary": true,
      "artifacts": [
        "docs/roadmap/compliance/"
      ],
      "gates": [
        "compliance lane"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    },
    "creativityInnovation": {
      "notApplicable": true,
      "reason": "Innovation narratives live in docs/product/ and docs/architecture/; this layer routes only",
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    },
    "commercialValue": {
      "primary": true,
      "artifacts": [
        "docs/roadmap/gtm/",
        "docs/roadmap/partnerships/"
      ],
      "gates": [
        "GTM lane"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    },
    "defensiveMoat": {
      "secondary": true,
      "artifacts": [
        "docs/roadmap/README.md"
      ],
      "gates": [
        "fleet decision trace"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    },
    "agenticEmpowerment": {
      "secondary": true,
      "artifacts": [
        "docs/roadmap/agile/README.md"
      ],
      "gates": [
        "pointer to agile/ hub"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    },
    "ecosystemIntegration": {
      "primary": true,
      "artifacts": [
        "docs/roadmap/README.md"
      ],
      "gates": [
        "XR + pm links"
      ],
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    },
    "ipMagic": {
      "notApplicable": true,
      "reason": "IP magic scored in docs/product/acceptance and reference implementations",
      "minBar": "≥100 layer order; reference hubs 100",
      "witness": "audit/evidence/mpr-roadmap-layer-latest.json"
    }
  },
  "fractalMpr": {
    "policy": "pm/spec/docs-fractal-mpr-policy.json",
    "layerWitness": "audit/evidence/mpr-roadmap-layer-latest.json",
    "scorecard": "docs/roadmap/scorecard.md",
    "rollupFrom": [
      "file",
      "folder"
    ],
    "scorecardIsReadOnlyRollup": true
  }
}
